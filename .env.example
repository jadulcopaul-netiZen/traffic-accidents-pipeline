#Example environment configuration for the Traffic Accident Analytics Pipeline. Copy this file to .env and replace the placeholder database values with your local PostgreSQL credentials. File paths are relative to the project root.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

DB_DATA_PATH=Data/archive/traffic_accidents.csv
TRANSFORMED_DATA_PATH=Data/versions
VIEWS_PATH=sql/views/views.sql
VISUALS_PATH=scripts/views_py